# Database — Supabase connection string
# Settings > Database > Connection string > URI (Session mode, port 5432)
DATABASE_URL=postgresql://postgres.[your-ref]:[your-password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=change-me-to-random-string

# Agent API (/api/agent) — klucz dla integracji maszynowych; wygeneruj np.
# `openssl rand -hex 32`. Bez tej zmiennej endpoint agenta jest wyłączony (503).
AGENT_API_KEY=change-me-to-long-random-string

# Server
PORT=3001

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
